{
  "name": "repath-mobile",
  "private": true,
  "version": "0.0.1",
  "main": "index.js",
  "scripts": {
    "start": "npx expo start",
    "smoke": "node scripts/smoke.js",
    "fetch:model": "node scripts/run-python.js ml/training/fetch-yolov8n-tflite.py",
    "build:retraining:manifest": "node ml/training/build-retraining-manifest.js",
    "build:annotation:bundle": "node ml/training/build-annotation-bundle.js",
    "validate:annotation:bundle": "node ml/training/validate-annotation-bundle.js",
    "validate:annotation:bundle:strict": "node ml/training/validate-annotation-bundle.js --strict",
    "export:model:candidate": "node scripts/run-python.js ml/training/export-candidate-from-retraining.py",
    "build:poc:curbside": "node scripts/build-poc-curbside-assets.js",
    "build:taxonomy": "node ml/data/build-taxonomy.js",
    "build:benchmark:manifest": "node ml/eval/build-benchmark-manifest.js",
    "build:benchmark:retraining-queue": "node ml/eval/build-retraining-queue.js",
    "check:benchmark:coverage": "node ml/eval/check-benchmark-coverage.js",
    "analyze:benchmark:results": "node ml/eval/analyze-benchmark-results.js",
    "compare:benchmark:results": "node ml/eval/compare-benchmark-results.js",
    "plan:benchmark:priority": "node ml/eval/plan-benchmark-priority.js",
    "plan:benchmark:coverage-expansion": "node ml/eval/plan-benchmark-coverage-expansion.js",
    "seed:benchmark:depth": "node ml/eval/seed-benchmark-depth-variants.js",
    "seed:benchmark:negatives": "node ml/eval/seed-negative-benchmark-entries.js --count 20",
    "build:benchmark:batches": "node ml/eval/build-benchmark-batches.js",
    "build:benchmark:template": "node ml/eval/build-benchmark-completion-template.js --out test/benchmarks/benchmark-completion-template.csv",
    "sync:benchmark:progress": "node ml/eval/sync-benchmark-progress.js",
    "audit:benchmark:dataset": "node ml/eval/audit-benchmark-dataset.js",
    "export:benchmark:unresolved": "node ml/eval/export-unresolved-benchmark-rows.js",
    "dedupe:benchmark:manifest": "node ml/eval/dedupe-benchmark-manifest.js",
    "suggest:benchmark:kaggle": "node ml/data/suggest-benchmark-from-kaggle.js --merge-into test/benchmarks/benchmark-labeled.csv",
    "suggest:benchmark:online": "node ml/data/suggest-benchmark-online.js --merge-into test/benchmarks/benchmark-labeled.csv",
    "suggest:benchmark:online:bulk": "node ml/data/suggest-benchmark-online-bulk.js",
    "suggest:benchmark:negatives": "node ml/data/suggest-negative-online.js --merge-into test/benchmarks/benchmark-labeled.csv",
    "sync:benchmark:labeled-from-manifest": "node ml/data/sync-labeled-from-manifest.js",
    "dedupe:benchmark:labeled": "node ml/data/dedupe-benchmark-labeled.js",
    "merge:benchmark:retraining-queue": "node ml/data/merge-retraining-queue.js --dry-run",
    "fill:benchmark:retraining-negatives": "node ml/data/fill-retraining-negatives.js",
    "apply:benchmark:coverage-expansion": "node ml/data/merge-coverage-expansion-template.js",
    "bootstrap:dataset:kaggle": "node ml/data/bootstrap-kaggle-dataset.js",
    "normalize:benchmark:urls": "node ml/data/normalize-benchmark-labeled-urls.js",
    "build:benchmark:resolved": "node ml/eval/build-resolved-benchmark-manifest.js",
    "run:benchmark:pipeline": "node ml/eval/run-benchmark-pipeline.js",
    "ml:scaffold": "npm run build:taxonomy && npm run build:benchmark:manifest && npm run check:benchmark:coverage",
    "ml:labeling:queue": "npm run plan:benchmark:priority && npm run plan:benchmark:coverage-expansion && npm run build:benchmark:batches && npm run build:benchmark:template",
    "ml:labeling:ingest": "npm run sync:benchmark:labeled-from-manifest && npm run apply:benchmark:coverage-expansion && npm run suggest:benchmark:kaggle && npm run suggest:benchmark:online && npm run suggest:benchmark:negatives && npm run normalize:benchmark:urls && npm run dedupe:benchmark:labeled && npm run sync:benchmark:progress -- --completed test/benchmarks/benchmark-labeled.csv --clear-empty-url",
    "ml:labeling:ingest:deep": "npm run sync:benchmark:labeled-from-manifest && npm run apply:benchmark:coverage-expansion && npm run suggest:benchmark:kaggle && npm run suggest:benchmark:online:bulk -- --passes 6 --limit 40 && npm run suggest:benchmark:negatives && npm run normalize:benchmark:urls && npm run dedupe:benchmark:labeled && npm run sync:benchmark:progress -- --completed test/benchmarks/benchmark-labeled.csv --clear-empty-url",
    "ml:evaluate": "npm run build:benchmark:resolved && npm run benchmark:model:resolved",
    "ml:all": "npm run run:benchmark:pipeline -- --skip-benchmark",
    "benchmark:model": "node scripts/run-python.js ml/eval/benchmark-model.py --manifest test/benchmarks/benchmark-manifest.seed.json",
    "benchmark:model:v2": "node scripts/run-python.js ml/eval/benchmark-model.py --manifest test/benchmarks/municipal-benchmark-manifest-v2.json",
    "benchmark:model:resolved": "node scripts/run-python.js ml/eval/benchmark-model.py --manifest test/benchmarks/municipal-benchmark-manifest.resolved.json",
    "benchmark:model:resolved:supported": "node scripts/run-python.js ml/eval/benchmark-model.py --manifest test/benchmarks/municipal-benchmark-manifest.resolved.json --supported-only",
    "benchmark:model:resolved:supported:analyze": "npm run benchmark:model:resolved:supported && npm run analyze:benchmark:results",
    "benchmark:model:resolved:plan": "npm run benchmark:model:resolved:supported && npm run analyze:benchmark:results && npm run build:benchmark:retraining-queue",
    "benchmark:model:candidate": "node ml/eval/benchmark-candidate-model.js --supported-only",
    "benchmark:model:candidate:compare": "npm run benchmark:model:candidate && npm run compare:benchmark:results",
    "extract:classes": "node scripts/extract-class-list.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "npx expo prebuild",
    "postprebuild": "node scripts/patch-expo-prebuild.js",
    "clean": "rm -rf node_modules android ios",
    "test": "node test/run-tests.cjs",
    "test:coverage": "npx --yes c8 --all --include='src/domain/**/*.js' --include='scripts/**/*.js' --reporter=text-summary --reporter=lcov --reporter=json-summary node test/run-tests.cjs"
  },
  "dependencies": {
    "buffer": "^6.0.3",
    "expo": "^54.0.33",
    "expo-build-properties": "~0.14.0",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-location": "~19.0.8",
    "expo-system-ui": "~5.0.4",
    "jpeg-js": "^0.4.4",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-fast-tflite": "^1.6.1",
    "react-native-safe-area-context": "^5.0.0",
    "react-native-vision-camera": "^4.7.3",
    "react-native-worklets-core": "^1.5.0"
  },
  "devDependencies": {
    "@babel/plugin-proposal-nullish-coalescing-operator": "npm:@babel/plugin-transform-nullish-coalescing-operator@^7.22.15",
    "@babel/plugin-proposal-optional-chaining": "npm:@babel/plugin-transform-optional-chaining@^7.22.15",
    "@babel/plugin-transform-nullish-coalescing-operator": "^7.22.15",
    "@babel/plugin-transform-optional-chaining": "^7.22.15",
    "@babel/plugin-transform-template-literals": "^7.22.15",
    "@react-native-community/cli": "^14.0.1",
    "babel-preset-expo": "~54.0.10"
  }
}
